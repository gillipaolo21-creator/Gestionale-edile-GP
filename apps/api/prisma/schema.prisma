// Configurazione Core Prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------------------

enum StatoCommessa {
  PREVENTIVO
  AGGIUDICATO
  IN_CORSO
  SOSPESO
  CHIUSO
}

enum TipoOpera {
  MOVIMENTO_TERRA
  CAPANNONE_LOGISTICO
  INFRASTRUTTURA_STRADALE
  OPERE_CIVILI
  PAVIMENTAZIONE
  OPERE_VERDE
  ALTRO
}

enum StatoSAL {
  BOZZA
  APPROVATO
  FATTURABILE
}

enum TipoSAL {
  ATTIVO
  PASSIVO
}

enum StatoPagamento {
  DA_PAGARE
  PARZIALE
  PAGATO
}

enum TipoDocumentoFiscale {
  FATTURA_ATTIVA
  FATTURA_PASSIVA
  NOTA_CREDITO
}

enum StatoMezzo {
  OPERATIVO
  IN_MANUTENZIONE
  FERMO
  DISMESSO
}

enum TipoMezzo {
  ESCAVATORE
  DUMPER
  BULLDOZER
  BETONIERA
  AUTOCARRO
  AUTOGRÙ
  COMPATTATORE
  PALA_MECCANICA
  FINITRICI
  RULLO_COMPRESSORE
  ALTRO
}

enum Qualifica {
  OPERAIO_COMUNE
  OPERAIO_SPECIALIZZATO
  CAPOCANTIERE
  GRUISTA
  AUTISTA
  TECNICO
  IMPIEGATO
  GEOMETRA
  INGEGNERE
}

enum TipoDocumentoSicurezza {
  POS
  DVR
  DUVRI
  PIANO_SICUREZZA
  VERBALE_RIUNIONE
  ATTESTATO_CORSO
  ALTRO
}

enum RuoloUtente {
  ADMIN
  DIRETTORE_LAVORI
  CAPOCANTIERE
  VIEWER
}

enum TipoEntitaDocumento {
  COMMESSA
  PERSONALE
  MEZZO
  SUBAPPALTATORE
  SAL
  FATTURA
}

// -----------------------------------------------------------------------------
// MODELLI DOMINIO
// -----------------------------------------------------------------------------

model User {
  id           String      @id @default(cuid())
  email        String      @unique
  passwordHash String      @map("password_hash")
  ruolo        RuoloUtente @default(VIEWER)
  nome         String?
  cognome      String?
  attivo       Boolean     @default(true)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  @@map("users")
}

// -----------------------------------------------------------------------------
// SOCIETA'
// -----------------------------------------------------------------------------

model Societa {
  id            String   @id @default(cuid())
  codice        String   @unique
  nome          String
  attiva        Boolean  @default(true)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  commesse      Commessa[]
  materiali     Materiale[]
  presenze      PresenzaGiornaliera[]
  assegnazioni  AssegnazioneMezzo[]
  contrattiSubappalto ContrattoSubappalto[]
  fatture       Fattura[]
  appaltoVoci   AppaltoVoce[]

  @@map("societa")
}

model Commessa {
  id                   String        @id @default(cuid())
  societaId            String        @map("societa_id")
  codiceIdentificativo String        @unique @map("codice_identificativo")
  nomeCantiere         String        @map("nome_cantiere")
  committente          String?
  tipoOpera            TipoOpera     @default(ALTRO) @map("tipo_opera")
  indirizzo            String?
  citta                String?
  cap                  String?
  provincia            String?
  gpsLat               Float?        @map("gps_lat")
  gpsLng               Float?        @map("gps_lng")
  responsabile         String?
  importoContratto     Float         @default(0) @map("importo_contratto")
  importoLavoriPropri  Float         @default(0) @map("importo_lavori_propri")
  stato                StatoCommessa @default(PREVENTIVO)
  dataInizio           DateTime?     @map("data_inizio")
  dataFinePrevista     DateTime?     @map("data_fine_prevista")
  dataFineEffettiva    DateTime?     @map("data_fine_effettiva")
  note                 String?
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")

  presenze             PresenzaGiornaliera[]
  assegnazioniMezzi    AssegnazioneMezzo[]
  materiali            Materiale[]
  contratti            ContrattoSubappalto[]
  sal                  Sal[]
  fatture              Fattura[]
  documenti            Documento[]
  scadenzeDocSicurezza DocumentoSicurezza[]
  appaltoVoci          AppaltoVoce[]

  societa              Societa       @relation(fields: [societaId], references: [id], onDelete: Restrict)

  @@index([stato])
  @@index([responsabile])
  @@index([societaId])
  @@map("commesse")
}

// -----------------------------------------------------------------------------
// PERSONALE
// -----------------------------------------------------------------------------

model Personale {
  id             String     @id @default(cuid())
  matricola      String     @unique
  nome           String
  cognome        String
  qualifica      Qualifica  @default(OPERAIO_COMUNE)
  costoOrario    Float      @default(0) @map("costo_orario")
  telefono       String?
  email          String?
  codiceFiscale  String?    @unique @map("codice_fiscale")
  dataAssunzione DateTime?  @map("data_assunzione")
  attivo         Boolean    @default(true)
  note           String?
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  presenze             PresenzaGiornaliera[]
  scadenzeCorsi        ScadenzaCorsoSicurezza[]
  dpiAssegnati         DpiAssegnato[]

  @@map("personale")
}

model PresenzaGiornaliera {
  id          String    @id @default(cuid())
  personaleId String    @map("personale_id")
  commessaId  String    @map("commessa_id")
  societaId   String    @map("societa_id")
  data        DateTime
  oreOrdine   Float     @default(8) @map("ore_ordinarie")
  oreExtra    Float     @default(0) @map("ore_extra")
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  personale   Personale @relation(fields: [personaleId], references: [id], onDelete: Cascade)
  commessa    Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  societa     Societa   @relation(fields: [societaId], references: [id], onDelete: Restrict)

  @@unique([personaleId, commessaId, data])
  @@index([commessaId])
  @@index([societaId])
  @@index([data])
  @@map("presenze_giornaliere")
}

// -----------------------------------------------------------------------------
// SICUREZZA PERSONALE
// -----------------------------------------------------------------------------

model ScadenzaCorsoSicurezza {
  id          String    @id @default(cuid())
  personaleId String    @map("personale_id")
  tipoCorso   String    @map("tipo_corso")
  dataCorso   DateTime  @map("data_corso")
  scadenza    DateTime
  ente        String?
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  personale   Personale @relation(fields: [personaleId], references: [id], onDelete: Cascade)

  @@index([personaleId])
  @@index([scadenza])
  @@map("scadenze_corsi_sicurezza")
}

model DpiAssegnato {
  id          String    @id @default(cuid())
  personaleId String    @map("personale_id")
  tipoDpi     String    @map("tipo_dpi")
  dataConsegna DateTime @map("data_consegna")
  scadenza    DateTime?
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  personale   Personale @relation(fields: [personaleId], references: [id], onDelete: Cascade)

  @@index([personaleId])
  @@map("dpi_assegnati")
}

// -----------------------------------------------------------------------------
// MEZZI & ATTREZZATURE
// -----------------------------------------------------------------------------

model Mezzo {
  id              String     @id @default(cuid())
  codice          String     @unique
  descrizione     String
  tipo            TipoMezzo  @default(ALTRO)
  targa           String?
  annoImmatricol  Int?       @map("anno_immatricolazione")
  costoOrario     Float      @default(0) @map("costo_orario")
  proprietario    String?
  stato           StatoMezzo @default(OPERATIVO)
  note            String?
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  assegnazioni    AssegnazioneMezzo[]
  scadenze        ScadenzaMezzo[]

  @@map("mezzi")
}

model AssegnazioneMezzo {
  id          String    @id @default(cuid())
  mezzoId     String    @map("mezzo_id")
  commessaId  String    @map("commessa_id")
  societaId   String    @map("societa_id")
  dataInizio  DateTime  @map("data_inizio")
  dataFine    DateTime? @map("data_fine")
  oreImpiegate Float    @default(0) @map("ore_impiegate")
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  mezzo       Mezzo    @relation(fields: [mezzoId], references: [id], onDelete: Cascade)
  commessa    Commessa @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  societa     Societa  @relation(fields: [societaId], references: [id], onDelete: Restrict)

  @@index([mezzoId])
  @@index([commessaId])
  @@index([societaId])
  @@map("assegnazioni_mezzi")
}

model ScadenzaMezzo {
  id          String    @id @default(cuid())
  mezzoId     String    @map("mezzo_id")
  tipoScadenza String   @map("tipo_scadenza")
  scadenza    DateTime
  completata  Boolean   @default(false)
  note        String?
  createdAt   DateTime  @default(now()) @map("created_at")

  mezzo       Mezzo     @relation(fields: [mezzoId], references: [id], onDelete: Cascade)

  @@index([mezzoId])
  @@index([scadenza])
  @@map("scadenze_mezzi")
}

// -----------------------------------------------------------------------------
// MATERIALI
// -----------------------------------------------------------------------------

model Materiale {
  id              String    @id @default(cuid())
  commessaId      String    @map("commessa_id")
  societaId       String    @map("societa_id")
  fornitoreNome   String    @map("fornitore_nome")
  descrizione     String
  unitaMisura     String    @map("unita_misura")
  quantita        Float
  prezzoUnitario  Float     @map("prezzo_unitario")
  dataConsegna    DateTime? @map("data_consegna")
  ddt             String?
  note            String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  commessa        Commessa  @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  societa         Societa   @relation(fields: [societaId], references: [id], onDelete: Restrict)

  @@index([commessaId])
  @@index([societaId])
  @@map("materiali")
}

// -----------------------------------------------------------------------------
// SUBAPPALTATORI
// -----------------------------------------------------------------------------

model Subappaltatore {
  id              String    @id @default(cuid())
  ragioneSociale  String    @map("ragione_sociale")
  piva            String?   @unique
  codiceFiscale   String?   @unique @map("codice_fiscale")
  referente       String?
  telefono        String?
  email           String?
  indirizzo       String?
  citta           String?
  specializzazione String?
  attivo          Boolean   @default(true)
  note            String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  contratti       ContrattoSubappalto[]

  @@map("subappaltatori")
}

model ContrattoSubappalto {
  id                  String         @id @default(cuid())
  commessaId          String         @map("commessa_id")
  subappaltatoreId    String         @map("subappaltatore_id")
  societaId           String         @map("societa_id")
  descrizioneOpera    String         @map("descrizione_opera")
  importoAffidato     Float          @map("importo_affidato")
  dataInizio          DateTime?      @map("data_inizio")
  dataFinePrevista    DateTime?      @map("data_fine_prevista")
  note                String?
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  commessa            Commessa       @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  subappaltatore      Subappaltatore @relation(fields: [subappaltatoreId], references: [id])
  societa             Societa        @relation(fields: [societaId], references: [id], onDelete: Restrict)
  sal                 Sal[]

  @@index([commessaId])
  @@index([subappaltatoreId])
  @@index([societaId])
  @@map("contratti_subappalto")
}

// -----------------------------------------------------------------------------
// SAL (Attivi verso committente + Passivi verso subappaltatori)
// -----------------------------------------------------------------------------

model Sal {
  id                       String              @id @default(cuid())
  commessaId               String              @map("commessa_id")
  contrattoSubappaltoId    String?             @map("contratto_subappalto_id")
  tipo                     TipoSAL             @default(ATTIVO)
  progressivo              Int
  dataCertificazione       DateTime            @map("data_certificazione")
  percentualeCompletamento Float               @map("percentuale_completamento")
  importoMaturato          Float               @map("importo_maturato")
  importoRitenuta          Float               @default(0) @map("importo_ritenuta")
  stato                    StatoSAL            @default(BOZZA)
  note                     String?
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")

  commessa                 Commessa            @relation(fields: [commessaId], references: [id], onDelete: Restrict)
  contrattoSubappalto      ContrattoSubappalto? @relation(fields: [contrattoSubappaltoId], references: [id])
  fatture                  Fattura[]

  @@unique([commessaId, tipo, progressivo])
  @@index([commessaId])
  @@map("sal")
}

// -----------------------------------------------------------------------------
// FATTURE
// -----------------------------------------------------------------------------

model Fattura {
  id                String               @id @default(cuid())
  tipoDocumento     TipoDocumentoFiscale @map("tipo_documento")
  commessaId        String               @map("commessa_id")
  societaId         String               @map("societa_id")
  salId             String?              @map("sal_id")
  numero            String?
  fornitoreCliente  String?              @map("fornitore_cliente")
  importoImponibile Float                @map("importo_imponibile")
  iva               Float                @default(0)
  dataEmissione     DateTime?            @map("data_emissione")
  dataScadenza      DateTime?            @map("data_scadenza")
  statoPagamento    StatoPagamento       @default(DA_PAGARE) @map("stato_pagamento")
  note              String?
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  commessa          Commessa             @relation(fields: [commessaId], references: [id], onDelete: Restrict)
  societa           Societa              @relation(fields: [societaId], references: [id], onDelete: Restrict)
  sal               Sal?                 @relation(fields: [salId], references: [id])

  @@index([commessaId])
  @@index([societaId])
  @@index([statoPagamento])
  @@map("fatture")
}

// -----------------------------------------------------------------------------
// SICUREZZA CANTIERE
// -----------------------------------------------------------------------------

model DocumentoSicurezza {
  id          String                  @id @default(cuid())
  commessaId  String                  @map("commessa_id")
  tipo        TipoDocumentoSicurezza  @default(ALTRO)
  titolo      String
  dataEmissione DateTime?             @map("data_emissione")
  scadenza    DateTime?
  fileUrl     String?                 @map("file_url")
  note        String?
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")

  commessa    Commessa                @relation(fields: [commessaId], references: [id], onDelete: Cascade)

  @@index([commessaId])
  @@index([scadenza])
  @@map("documenti_sicurezza")
}

// -----------------------------------------------------------------------------
// DOCUMENTI GENERICI
// -----------------------------------------------------------------------------

model Documento {
  id                String              @id @default(cuid())
  commessaId        String?             @map("commessa_id")
  entitaTipo        TipoEntitaDocumento @map("entita_tipo")
  entitaId          String              @map("entita_id")
  nomeFile          String              @map("nome_file")
  storageUrl        String              @map("storage_url")
  hashFile          String              @map("hash_file")
  categoria         String?
  sottocategoria    String?
  datiEstrattiJson  String?             @map("dati_estratti_json")
  stato             String?             @default("APPROVATO")
  mimeType          String?             @map("mime_type")
  dimensione        Int?
  createdAt         DateTime            @default(now()) @map("created_at")

  commessa    Commessa?           @relation(fields: [commessaId], references: [id])

  @@index([entitaTipo, entitaId])
  @@index([commessaId])
  @@map("documenti")
}

// -----------------------------------------------------------------------------
// APPALTO VOCI
// -----------------------------------------------------------------------------

model AppaltoVoce {
  id                 String   @id @default(cuid())
  commessaId         String   @map("commessa_id")
  parentId           String?  @map("parent_id")
  societaId          String   @map("societa_id")
  descrizione        String   @default("")
  unitaMisura        String   @default("") @map("unita_misura")
  quantita           Float    @default(0)
  prezzoUnitario     Float    @default(0) @map("prezzo_unitario")
  avanzamentoPercent Float    @default(0) @map("avanzamento_percent")
  costoPrevisto      Float    @default(0) @map("costo_previsto")
  costoEffettivo     Float    @default(0) @map("costo_effettivo")
  ricavoPrevisto     Float    @default(0) @map("ricavo_previsto")
  ricavoEffettivo    Float    @default(0) @map("ricavo_effettivo")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  commessa Commessa @relation(fields: [commessaId], references: [id], onDelete: Cascade)
  societa  Societa  @relation(fields: [societaId], references: [id], onDelete: Restrict)

  @@index([commessaId])
  @@index([societaId])
  @@map("appalto_voci")
}

// -----------------------------------------------------------------------------
// AUDIT LOG
// -----------------------------------------------------------------------------

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?  @map("user_id")
  userEmail     String?  @map("user_email")
  azione        String
  entita        String
  entitaId      String   @map("entita_id")
  dataPrecedente String? @map("data_precedente")
  dataNuova     String?  @map("data_nuova")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([entita, entitaId])
  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

