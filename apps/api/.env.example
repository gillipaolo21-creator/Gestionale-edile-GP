# ─── Database ────────────────────────────────────────────────────────────────
# URL di connessione PostgreSQL
DATABASE_URL="postgresql://postgres:password@localhost:5432/brescianicrm?schema=public"

# ─── Redis (code job) ─────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── Storage documenti ────────────────────────────────────────────────────────
# Percorso radice dove vengono salvati i file delle commesse.
# Su Windows, usare le doppie backslash oppure singoli forward-slash.
STORAGE_BASE_PATH=C:\Users\Utente\bresciani.group\01.Operativo - Documenti\Commesse
