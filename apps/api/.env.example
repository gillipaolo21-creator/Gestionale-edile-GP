# ─── Database ───────────────────────────────────────────────────────────────
# PostgreSQL connection string (Prisma)
DATABASE_URL="postgresql://postgres:password@localhost:5432/brescianicrm"

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret key for JWT signing (change in production!)
JWT_SECRET="change-me-in-production"
# JWT expiry duration (e.g. 8h, 1d)
JWT_EXPIRES_IN="8h"

# ─── Storage ─────────────────────────────────────────────────────────────────
# Absolute path to the root folder where commessa documents are stored
STORAGE_BASE_PATH="C:\\Users\\Utente\\bresciani.group\\01.Operativo - Documenti\\Commesse"

# ─── CORS ────────────────────────────────────────────────────────────────────
# URL of the Next.js frontend (used for CORS allow-list)
FRONTEND_URL="http://localhost:3000"

# ─── Redis (BullMQ job queue) ─────────────────────────────────────────────────
REDIS_HOST="localhost"
REDIS_PORT="6379"

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Set to "production" to disable Swagger and enable production error handling
NODE_ENV="development"
