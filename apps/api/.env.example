# ─── Database ───────────────────────────────────────────────────────────────
# SQLite connection string (Prisma) — file path relative to packages/db
DATABASE_URL="file:./dev.db"

# ─── Authentication ──────────────────────────────────────────────────────────
# Secret key for JWT signing (change in production — use 32+ random chars)
JWT_SECRET="change-me-in-production"
# JWT expiry duration (e.g. 8h, 1d)
JWT_EXPIRES_IN="8h"

# ─── Storage ─────────────────────────────────────────────────────────────────
# Absolute path to the root folder where commessa documents are stored
STORAGE_BASE_PATH="C:\\Users\\Utente\\strade-servizi\\01.Operativo - Documenti\\Commesse"

# ─── CORS ────────────────────────────────────────────────────────────────────
# URL of the Next.js frontend (used for CORS allow-list)
FRONTEND_URL="http://localhost:3000"

# ─── Runtime ─────────────────────────────────────────────────────────────────
# Set to "production" to disable Swagger and enable production error handling
NODE_ENV="development"

# ─── API Server ───────────────────────────────────────────────────────────────
API_PORT="3001"
API_HOST="0.0.0.0"

