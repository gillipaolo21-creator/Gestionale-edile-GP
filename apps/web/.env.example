# ─── API Proxy ───────────────────────────────────────────────────────────────
# The Next.js rewrite proxy target (points to the NestJS API).
# Only change this if you run the API on a different host/port.
# Default (next.config.mjs hardcoded): http://127.0.0.1:3001
# NEXT_PUBLIC_API_URL="http://localhost:3001"

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV="development"
