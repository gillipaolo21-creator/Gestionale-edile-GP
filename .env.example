# ============================================================
# Gestionale Edile GP — Variabili d'ambiente
# Copia questo file in .env e compila i valori reali.
# NON committare il file .env su Git.
# ============================================================

# ---------------------------------------------------------------
# DATABASE (PostgreSQL)
# ---------------------------------------------------------------
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/gestionale_edile?schema=public"

# ---------------------------------------------------------------
# AUTENTICAZIONE JWT
# ---------------------------------------------------------------
# Segreto per firmare i token JWT (minimo 32 caratteri, usa un valore casuale)
JWT_SECRET="cambia-questo-con-un-segreto-molto-lungo-e-casuale"
# Durata validità token (es. "8h", "1d", "7d")
JWT_EXPIRES_IN="8h"

# ---------------------------------------------------------------
# CORS
# ---------------------------------------------------------------
# URL del frontend (Next.js)
FRONTEND_URL="http://localhost:3000"

# ---------------------------------------------------------------
# STORAGE FILE
# ---------------------------------------------------------------
# Cartella radice dove vengono salvati i documenti caricati
# Su Windows usa il formato: C:\\Utente\\bresciani.group\\Commesse
# Su Linux/Mac usa il formato: /opt/gestionale/storage
STORAGE_BASE_PATH="C:\\Users\\Utente\\bresciani.group\\01.Operativo - Documenti\\Commesse"

# ---------------------------------------------------------------
# REDIS (BullMQ — code per import Excel)
# ---------------------------------------------------------------
REDIS_HOST="localhost"
REDIS_PORT="6379"
# Decommentare se Redis richiede autenticazione
# REDIS_PASSWORD=""

# ---------------------------------------------------------------
# AMBIENTE
# ---------------------------------------------------------------
# "development" | "production" | "test"
NODE_ENV="development"

# ---------------------------------------------------------------
# API SERVER
# ---------------------------------------------------------------
# Porta su cui gira il backend NestJS
API_PORT="3001"
